package onet:extension;

interface document-export {
    record theme {
        dark: bool,
        background: u32,
        foreground: u32,
        border: u32,
        muted: u32,
        accent: u32,
        danger: u32,
        font-family: string,
    }

    record request {
        exporter: string,
        format: string,
        title: string,
        source: string,
        theme: theme,
    }

    record artifact {
        media-type: string,
        extension: string,
        bytes: list<u8>,
    }
}

world document-exporter {
    use document-export.{request, artifact};
    export export-document: func(input: request) -> result<artifact, string>;
}
