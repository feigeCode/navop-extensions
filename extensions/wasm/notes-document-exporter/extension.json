{
  "schema_version": 1,
  "id": "com.navop.exporter.notes-documents",
  "name": "Notes Document Exporter",
  "description": "使用纯 Rust WASM 将 Notes 文档导出为自包含 HTML、PDF 和 Word DOCX，不依赖 Chrome、Office 或宿主转换库。 Pure Rust WASM exporter for self-contained HTML, PDF, and Word DOCX files without Chrome, Office, or host-side conversion libraries.",
  "version": "0.1.0",
  "publisher": "Navop",
  "engines": { "onetcli": ">=0.7.0" },
  "api": { "extension": "1.0" },
  "runtime": {
    "wasm": [{
      "id": "notes-document-exporter",
      "module": "wasm/notes_document_exporter_wasm.wasm",
      "kind": "component",
      "timeout_ms": 15000,
      "max_memory_mb": 128
    }]
  },
  "permissions": [],
  "contributes": {
    "documentExporters": [{
      "id": "notes-documents",
      "displayName": "HTML, PDF and Word",
      "runtimeId": "notes-document-exporter",
      "function": "export-document",
      "formats": ["html", "pdf", "docx"],
      "outputMediaTypes": [
        "text/html",
        "application/pdf",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
      ],
      "priority": 100
    }]
  }
}
