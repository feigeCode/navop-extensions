{
  "schema_version": 1,
  "id": "com.onetcli.editor.zed",
  "name": "Zed External Editor",
  "description": "静态复合扩展，通过 Zed 编辑 Navop SFTP 远程文件，支持远程文件拉取、保存回传和外部编辑器协作。 Static composite extension for editing Navop SFTP remote files with Zed, including remote fetch, save-back, and external editor workflows.",
  "version": "0.1.1",
  "publisher": "OnetCli",
  "engines": {
    "onetcli": ">=0.8.6"
  },
  "categories": [
    "Editor",
    "SFTP"
  ],
  "contributes": {
    "remoteFileEditors": [
      {
        "id": "zed-macos",
        "displayName": "Zed",
        "platforms": [
          "macos"
        ],
        "fileMasks": [
          "*"
        ],
        "priority": 90,
        "command": {
          "launchMode": "macos_open",
          "programCandidates": [
            "/Applications/Zed.app/Contents/MacOS/zed"
          ],
          "args": [
            "{file}"
          ]
        }
      },
      {
        "id": "zed-linux",
        "displayName": "Zed",
        "platforms": [
          "linux"
        ],
        "fileMasks": [
          "*"
        ],
        "priority": 90,
        "command": {
          "programCandidates": [
            "zed"
          ],
          "args": [
            "{file}"
          ]
        }
      }
    ]
  }
}
