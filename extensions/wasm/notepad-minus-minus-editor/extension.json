{
  "schema_version": 1,
  "id": "com.onetcli.editor.notepad-minus-minus",
  "name": "Notepad-- External Editor",
  "description": "静态复合扩展，通过 Notepad-- 编辑 Navop SFTP 远程文件，支持远程文件拉取、保存回传和外部编辑器协作。 Static composite extension for editing Navop SFTP remote files with Notepad--, including remote fetch, save-back, and external editor workflows.",
  "version": "0.1.1",
  "publisher": "OnetCli",
  "engines": {
    "onetcli": ">=0.8.6"
  },
  "categories": [
    "Editor",
    "SFTP"
  ],
  "contributes": {
    "remoteFileEditors": [
      {
        "id": "notepad-minus-minus",
        "displayName": "Notepad--",
        "platforms": [
          "macos"
        ],
        "fileMasks": [
          "*"
        ],
        "priority": 100,
        "command": {
          "launchMode": "macos_open",
          "programCandidates": [
            "/Applications/Notepad--.app/Contents/MacOS/Notepad--"
          ],
          "args": [
            "{file}"
          ]
        }
      }
    ]
  }
}
