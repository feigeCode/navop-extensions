{
  "schema_version": 1,
  "id": "com.navop.renderer.mermaid",
  "name": "Mermaid Renderer",
  "description": "使用 Rust WASM 将 Notes 中的 Mermaid 图表渲染为安全 SVG，支持流程图、时序图和其他 Mermaid 文档块的预览。 Rust WASM renderer that converts Mermaid blocks in Notes into safe SVG for flowcharts, sequence diagrams, and other Mermaid document previews.",
  "version": "0.1.0",
  "publisher": "Navop",
  "engines": { "onetcli": ">=0.7.0" },
  "api": { "extension": "1.0" },
  "runtime": {
    "wasm": [{
      "id": "mermaid-renderer",
      "module": "wasm/mermaid_renderer_wasm.wasm",
      "kind": "component",
      "timeout_ms": 5000,
      "max_memory_mb": 128
    }]
  },
  "permissions": [],
  "contributes": {
    "documentRenderers": [{
      "id": "mermaid",
      "displayName": "Mermaid",
      "runtimeId": "mermaid-renderer",
      "function": "render-document",
      "blockKinds": ["mermaid"],
      "outputMediaTypes": ["image/svg+xml"],
      "priority": 100
    }]
  }
}
