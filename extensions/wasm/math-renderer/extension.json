{
  "schema_version": 1,
  "id": "com.navop.renderer.math",
  "name": "Math Renderer",
  "description": "使用 Rust WASM 将 Notes 中的 LaTeX 数学块渲染为自包含 SVG，支持公式预览、导出和离线文档展示。 Rust WASM renderer that turns LaTeX math blocks in Notes into self-contained SVG for formula previews, exports, and offline document viewing.",
  "version": "0.1.0",
  "publisher": "Navop",
  "engines": { "onetcli": ">=0.7.0" },
  "api": { "extension": "1.0" },
  "runtime": { "wasm": [{ "id": "math-renderer", "module": "wasm/math_renderer_wasm.wasm", "kind": "component", "timeout_ms": 5000, "max_memory_mb": 128 }] },
  "permissions": [],
  "contributes": { "documentRenderers": [{ "id": "math", "displayName": "Math", "runtimeId": "math-renderer", "function": "render-document", "blockKinds": ["math"], "outputMediaTypes": ["image/svg+xml"], "priority": 100 }] }
}
