{
  "schema_version": 1,
  "id": "com.onetcli.importer.redis-desktop",
  "name": "Redis Desktop Importer",
  "description": "从 Redis Desktop 等桌面客户端的本地配置中发现 Redis 连接，并通过 Rust WASM 导入到 Navop；适合开发环境迁移。 Discovers Redis connections from local Redis desktop client configurations and imports them into Navop through Rust WASM for development environment migration.",
  "version": "0.1.0",
  "publisher": "Navop",
  "engines": {
    "onetcli": ">=0.7.0"
  },
  "api": {
    "extension": "1.0"
  },
  "runtime": {
    "wasm": [
      {
        "id": "redis-desktop-importer",
        "module": "wasm/redis_desktop_importer_wasm.wasm",
        "kind": "component",
        "timeout_ms": 5000,
        "max_memory_mb": 64
      }
    ]
  },
  "permissions": [
    "fs:read:~/Library/Application Support/com.hepengju.redis/store.json",
    "fs:read:%APPDATA%/com.hepengju.redis/store.json",
    "fs:read:~/.config/com.hepengju.redis/store.json"
  ],
  "contributes": {
    "connectionImporters": [
      {
        "id": "redis-desktop",
        "runtimeId": "redis-desktop-importer",
        "displayName": "Redis Desktop",
        "description": "从 Redis 桌面客户端配置中发现并导入 Redis 连接元数据。 Discover and import Redis connection metadata from Redis desktop client configurations.",
        "icon": "database",
        "outputKinds": [
          "database"
        ],
        "platforms": [
          "macos",
          "windows",
          "linux"
        ],
        "candidateFiles": [
          {
            "id": "redis-desktop-macos-store",
            "platform": "macos",
            "path": "~/Library/Application Support/com.hepengju.redis/store.json"
          },
          {
            "id": "redis-desktop-windows-store",
            "platform": "windows",
            "path": "%APPDATA%/com.hepengju.redis/store.json"
          },
          {
            "id": "redis-desktop-linux-store",
            "platform": "linux",
            "path": "~/.config/com.hepengju.redis/store.json"
          }
        ]
      }
    ]
  }
}
