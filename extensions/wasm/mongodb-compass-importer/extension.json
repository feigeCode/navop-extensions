{
  "schema_version": 1,
  "id": "com.onetcli.importer.mongodb-compass",
  "name": "MongoDB Compass Importer",
  "description": "Rust WASM connection importer for MongoDB Compass",
  "version": "0.1.0",
  "publisher": "OnetCli",
  "engines": {
    "onetcli": ">=0.7.0"
  },
  "api": {
    "extension": "1.0"
  },
  "runtime": {
    "wasm": [
      {
        "id": "mongodb-compass-importer",
        "module": "wasm/mongodb_compass_importer_wasm.wasm",
        "kind": "component",
        "timeout_ms": 5000,
        "max_memory_mb": 64
      }
    ]
  },
  "permissions": [
    "fs:read:~/Library/Application Support/MongoDB Compass/Connections",
    "fs:read:%APPDATA%/MongoDB Compass/Connections",
    "fs:read:~/.config/MongoDB Compass/Connections"
  ],
  "contributes": {
    "connectionImporters": [
      {
        "id": "mongodb-compass",
        "runtimeId": "mongodb-compass-importer",
        "displayName": "MongoDB Compass",
        "description": "Import MongoDB connection metadata from MongoDB Compass",
        "icon": "database",
        "outputKinds": [
          "database"
        ],
        "platforms": [
          "macos",
          "windows",
          "linux"
        ],
        "candidateFiles": [
          {
            "id": "mongodb-compass-macos-connections",
            "platform": "macos",
            "path": "~/Library/Application Support/MongoDB Compass/Connections"
          },
          {
            "id": "mongodb-compass-windows-connections",
            "platform": "windows",
            "path": "%APPDATA%/MongoDB Compass/Connections"
          },
          {
            "id": "mongodb-compass-linux-connections",
            "platform": "linux",
            "path": "~/.config/MongoDB Compass/Connections"
          }
        ]
      }
    ]
  }
}
