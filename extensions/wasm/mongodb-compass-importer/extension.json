{
  "schema_version": 1,
  "id": "com.onetcli.importer.mongodb-compass",
  "name": "MongoDB Compass Importer",
  "description": "从 MongoDB Compass 的本地配置和连接元数据中发现 MongoDB 连接，并通过 Rust WASM 导入到 Navop；不会改变原始配置文件。 Discovers MongoDB connections from local MongoDB Compass configuration and metadata, then imports them into Navop through Rust WASM without modifying the source files.",
  "version": "0.1.0",
  "publisher": "Navop",
  "engines": {
    "onetcli": ">=0.7.0"
  },
  "api": {
    "extension": "1.0"
  },
  "runtime": {
    "wasm": [
      {
        "id": "mongodb-compass-importer",
        "module": "wasm/mongodb_compass_importer_wasm.wasm",
        "kind": "component",
        "timeout_ms": 5000,
        "max_memory_mb": 64
      }
    ]
  },
  "permissions": [
    "fs:read:~/Library/Application Support/MongoDB Compass/Connections",
    "fs:read:%APPDATA%/MongoDB Compass/Connections",
    "fs:read:~/.config/MongoDB Compass/Connections"
  ],
  "contributes": {
    "connectionImporters": [
      {
        "id": "mongodb-compass",
        "runtimeId": "mongodb-compass-importer",
        "displayName": "MongoDB Compass",
        "description": "从 MongoDB Compass 配置中发现并导入 MongoDB 连接元数据。 Discover and import MongoDB connection metadata from MongoDB Compass configuration.",
        "icon": "database",
        "outputKinds": [
          "database"
        ],
        "platforms": [
          "macos",
          "windows",
          "linux"
        ],
        "candidateFiles": [
          {
            "id": "mongodb-compass-macos-connections",
            "platform": "macos",
            "path": "~/Library/Application Support/MongoDB Compass/Connections"
          },
          {
            "id": "mongodb-compass-windows-connections",
            "platform": "windows",
            "path": "%APPDATA%/MongoDB Compass/Connections"
          },
          {
            "id": "mongodb-compass-linux-connections",
            "platform": "linux",
            "path": "~/.config/MongoDB Compass/Connections"
          }
        ]
      }
    ]
  }
}
