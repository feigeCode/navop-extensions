{
  "schema_version": 1,
  "id": "com.onetcli.importer.xshell",
  "name": "Xshell Importer",
  "description": "从 Xshell 会话文件中发现 SSH 连接配置，并通过 Rust WASM 导入到 Navop；支持批量迁移常用主机设置。 Discovers SSH connection settings from Xshell session files and imports them into Navop through Rust WASM for migrating frequently used hosts in batches.",
  "version": "0.1.1",
  "publisher": "OnetCli",
  "engines": {
    "onetcli": ">=0.7.0"
  },
  "api": {
    "extension": "1.0"
  },
  "runtime": {
    "wasm": [
      {
        "id": "xshell-importer",
        "module": "wasm/xshell_importer_wasm.wasm",
        "kind": "component",
        "timeout_ms": 5000,
        "max_memory_mb": 64
      }
    ]
  },
  "permissions": [
    "fs:read:%USERPROFILE%/Documents/NetSarang Computer/8/Xshell/Sessions",
    "fs:read:%USERPROFILE%/Documents/NetSarang Computer/7/Xshell/Sessions",
    "fs:read:%USERPROFILE%/Documents/NetSarang Computer/6/Xshell/Sessions",
    "fs:read:%APPDATA%/NetSarang/Xshell/Sessions"
  ],
  "contributes": {
    "connectionImporters": [
      {
        "id": "xshell",
        "runtimeId": "xshell-importer",
        "displayName": "Xshell",
        "description": "从 Xshell 会话文件发现并导入 SSH 连接。 Discover and import SSH connections from Xshell session files.",
        "icon": "terminal",
        "outputKinds": [
          "ssh"
        ],
        "platforms": [
          "windows"
        ],
        "candidateFiles": [
          {
            "id": "xshell-windows-v8-sessions",
            "platform": "windows",
            "path": "%USERPROFILE%/Documents/NetSarang Computer/8/Xshell/Sessions"
          },
          {
            "id": "xshell-windows-v7-sessions",
            "platform": "windows",
            "path": "%USERPROFILE%/Documents/NetSarang Computer/7/Xshell/Sessions"
          },
          {
            "id": "xshell-windows-v6-sessions",
            "platform": "windows",
            "path": "%USERPROFILE%/Documents/NetSarang Computer/6/Xshell/Sessions"
          },
          {
            "id": "xshell-windows-appdata-sessions",
            "platform": "windows",
            "path": "%APPDATA%/NetSarang/Xshell/Sessions"
          }
        ]
      }
    ]
  }
}
